<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <appSettings>
    <!-- Motor de base de datos: "Sqlite" (una sola caja, por defecto) o "SqlServer" (varias cajas). -->
    <add key="ProveedorBD" value="Sqlite" />

    <!-- Solo para SqlServer: cadena de conexión al servidor central. Descomentar y ajustar.
         Ejemplo (cada caja apunta al PC servidor):
    <add key="CadenaConexion" value="Server=SERVIDOR\SQLEXPRESS;Database=PosMaqueta;Integrated Security=true;TrustServerCertificate=true;" />
    -->

    <!-- Opcional (SQLite): carpeta para copiar los respaldos FUERA del disco local (red, USB, nube),
         para sobrevivir a una falla del disco. Descomentar y ajustar.
    <add key="CarpetaRespaldoExterno" value="\\SERVIDOR\Respaldos\POS" />
    -->

    <!-- Telemetría de fallos a la SEDE (monitoreo remoto). Solo envía ERROR/FATAL, en segundo
         plano y sin bloquear. Vacío LogCentralConexion = DESACTIVADO (1 caja sin monitoreo). -->
    <add key="TiendaId" value="" />                    <!-- ej: "BotilleriaEOS"; vacío = nombre del equipo -->
    <add key="CajaId" value="" />                      <!-- ej: "caja-01"; vacío = nombre del equipo -->
    <add key="LogCentralConexion" value="" />          <!-- ej: Server=100.93.168.1,1433;Database=PosCentral;User ID=pos_log;Password=...;TrustServerCertificate=true;Connect Timeout=5 -->
    <add key="LogCentralNivelMinimo" value="ERROR" />  <!-- ERROR (por defecto) o WARN -->
  </appSettings>
</configuration>
